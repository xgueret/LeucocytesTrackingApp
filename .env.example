# Variables injectées dans docker-compose.yml (déploiement)
# Copier ce fichier en .env à la racine et renseigner les valeurs.

# Clé secrète JWT (OBLIGATOIRE) — générer avec : openssl rand -hex 32
SECRET_KEY=

# Compte administrateur créé au premier démarrage (OBLIGATOIRE)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Code PIN admin (vérifié côté serveur)
ADMIN_PIN=

# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:3000
