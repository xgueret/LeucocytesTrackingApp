# Configuration de l'application
APP_NAME="API Suivi des Leucocytes"
APP_VERSION="1.0.0"

# Port du serveur
PORT=8081

# Chemin vers la base de données SQLite
DATABASE_URL="./data/leucocytes.db"

# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Environnement (development, production)
NODE_ENV="development"

# Clé secrète pour signer les JWT (OBLIGATOIRE)
# Générer avec : openssl rand -hex 32
SECRET_KEY=""

# Durée de validité d'un token JWT (ex: 30m, 1h, 7d)
TOKEN_EXPIRATION="30m"

# Compte administrateur créé au premier démarrage (OBLIGATOIRE)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""
